  },
  "devDependencies": {
    "@angular/common": "^16.0.0",
    "@angular/core": "^16.0.0",
    "@ng-bootstrap/ng-bootstrap": "^15.0.0",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^29.5.0",
